FROM golang:1.24.3-alpine AS build
WORKDIR /src
COPY go.mod ./
COPY cmd ./cmd
COPY internal ./internal
RUN --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/fugue-api ./cmd/fugue-api

FROM alpine:3.21
RUN apk add --no-cache ca-certificates
WORKDIR /app
COPY --from=build /out/fugue-api /usr/local/bin/fugue-api
ENTRYPOINT ["/usr/local/bin/fugue-api"]
